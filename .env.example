# FlowZint environment configuration
# Copy this file to .env and fill in what you need. EVERYTHING here is OPTIONAL —
# FlowZint runs fully (chat, scoring, booking, CRM) with an empty .env.

# ─────────────────────────────────────────────────────────────────────────────
# AI conversation (optional "turbo mode")
# ─────────────────────────────────────────────────────────────────────────────
# Lead SCORING is rule-based and needs NO key. This key only makes the chat
# replies more fluent and better at understanding free-text answers.
# Without it, FlowZint uses its built-in heuristic engine.
#
# ⚠️ If you set a key, make sure ANTHROPIC_MODEL is a model your account can
# access. If the model id is invalid, the app silently falls back to the
# heuristic engine (you'll see no error, just no improvement).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────────────
# Optional real integrations (all no-op unless set)
# ─────────────────────────────────────────────────────────────────────────────
# Real confirmation emails via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=FlowZint <hello@yourdomain.com>

# Real Slack alerts for hot leads (Incoming Webhook URL)
SLACK_WEBHOOK_URL=

# Fire events into an n8n workflow (webhook URL) for email/CRM automations
N8N_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Optional path override for the SQLite file. Defaults to ./data/flowzint.db
# FLOWZINT_DB_PATH=./data/flowzint.db
