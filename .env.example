# FlowZint environment configuration
# Copy this file to .env and fill in your values.

# Anthropic API key — used SERVER-SIDE ONLY (never exposed to the browser).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used for the qualification conversation.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: absolute or relative path for the SQLite database file.
# Defaults to ./data/flowzint.db
# FLOWZINT_DB_PATH=./data/flowzint.db
