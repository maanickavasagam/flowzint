# FlowZint environment configuration
# Copy this file to .env and fill in what you need. EVERYTHING here is OPTIONAL —
# FlowZint runs fully (chat, scoring, booking, CRM) with an empty .env.

# ─────────────────────────────────────────────────────────────────────────────
# AI conversation engine (all optional)
# ─────────────────────────────────────────────────────────────────────────────
# Lead SCORING is rule-based and needs NO key — it never calls an LLM.
# A key only makes the chat replies more fluent and better at understanding
# free-text answers. With no key, FlowZint runs its built-in rules engine.
#
# Reliability: whichever provider you pick, any failure (rate limit, outage,
# bad key, timeout) automatically falls back to the rules engine — the chat
# degrades, it never breaks.
#
# Pick one (auto-detected; Groq wins if both are set):

# Option A — Groq (free tier, fast). Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL lets you point this same code path at any OpenAI-compatible
# provider — Cerebras, OpenRouter, Together, Gemini's compat endpoint, etc.
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Option B — Anthropic (paid, per-token). https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Force a specific engine: groq | anthropic | rules  (leave unset to auto-detect)
# LLM_PROVIDER=

# ─────────────────────────────────────────────────────────────────────────────
# Optional real integrations (all no-op unless set)
# ─────────────────────────────────────────────────────────────────────────────
# Real confirmation emails — the app picks Gmail first, else Resend.
#
# Option A — Gmail SMTP (sends to ANY recipient, no domain needed):
#   1. Turn on 2-Step Verification for your Google account.
#   2. Create an "App password": https://myaccount.google.com/apppasswords
#   3. Paste the 16-char password below (spaces are fine).
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=FlowZint

# Option B — Resend (needs a VERIFIED domain to email arbitrary recipients;
# the onboarding@resend.dev sandbox only reaches your own account email)
RESEND_API_KEY=
RESEND_FROM=FlowZint <hello@yourdomain.com>

# Real Slack alerts for hot leads (Incoming Webhook URL)
SLACK_WEBHOOK_URL=

# Fire events into an n8n workflow (webhook URL) for email/CRM automations
N8N_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Optional path override for the SQLite file. Defaults to ./data/flowzint.db
# FLOWZINT_DB_PATH=./data/flowzint.db
